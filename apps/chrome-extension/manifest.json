{
  "manifest_version": 3,
  "name": "ScanPDF",
  "version": "1.0.0",
  "description": "Chuyển đổi và xử lý PDF trực tiếp từ trình duyệt.",
  "action": {
    "default_title": "ScanPDF",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "http://localhost:4000/*",
    "https://api.scanpdf.vn/*",
    "https://scanpdf.vn/*"
  ]
}
