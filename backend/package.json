{
  "name": "scanpdf-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,worker -c blue,magenta \"tsx watch src/server.ts\" \"tsx watch src/workers/conversion.worker.ts\"",
    "worker:dev": "tsx watch src/workers/conversion.worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "node dist/workers/conversion.worker.js",
    "lint": "tsc --noEmit",
    "test": "vitest run tests",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@payos/node": "^2.0.5",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^6.19.0",
    "@sentry/node": "^10.56.0",
    "@supabase/supabase-js": "^2.86.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.66.0",
    "cors": "^2.8.5",
    "dejavu-fonts-ttf": "^2.37.3",
    "docx": "^9.5.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.10",
    "otplib": "^13.4.1",
    "pdf-lib": "^1.17.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
