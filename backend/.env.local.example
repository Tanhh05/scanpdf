NODE_ENV=development
DATABASE_URL=postgresql://scanpdf:scanpdf@localhost:5432/scanpdf
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
PORT=4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
API_URL=http://localhost:4000/api
STORAGE_DRIVER=local
STORAGE_ROOT=../storage

GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# Local email defaults to disabled. Auth routes will print verification/reset URLs in the backend console.
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ScanPDF Local <no-reply@localhost>

OPENAI_MODEL=gpt-5.2
AI_PROVIDER=openai
GEMINI_MODEL=gemini-2.0-flash
CLEANUP_INTERVAL_MINUTES=1440
CLEANUP_BATCH_SIZE=200
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
