NODE_ENV=production
DATABASE_URL=
REDIS_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
PORT=4000
FRONTEND_URL=https://your-frontend.example.com
CORS_ORIGINS=https://your-frontend.example.com
API_URL=https://your-backend.example.com/api
STORAGE_DRIVER=local
STORAGE_ROOT=/tmp/scanpdf-storage

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend.example.com/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://your-backend.example.com/api/auth/github/callback

RESEND_API_KEY=
MAIL_FROM=ScanPDF <no-reply@your-domain.example>
# Or use SMTP instead of Resend:
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
AI_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CLEANUP_INTERVAL_MINUTES=1440
CLEANUP_BATCH_SIZE=200
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
